{
  "name": "@v3/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "default": "./src/schema.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./rls": {
      "types": "./src/rls.ts",
      "default": "./src/rls.ts"
    },
    "./helpers": {
      "types": "./src/helpers.ts",
      "default": "./src/helpers.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "drizzle-kit migrate",
    "drizzle:studio": "drizzle-kit studio",
    "seed": "tsx scripts/seed.ts",
    "migrate:users": "tsx scripts/migrate-users.ts",
    "migrate:contacts": "tsx scripts/migrate-contacts.ts",
    "migrate:properties": "tsx scripts/migrate-properties.ts",
    "migrate:services": "tsx scripts/migrate-services.ts",
    "migrate:orders": "tsx scripts/migrate-orders.ts",
    "migrate:history": "tsx scripts/migrate-history.ts",
    "migrate:notes": "tsx scripts/migrate-notes.ts",
    "migrate:archive": "tsx scripts/archive-cancellations.ts",
    "migrate:validate": "tsx scripts/validate-migration.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@v3/types": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "drizzle-zod": "^0.5.1",
    "pg": "^8.13.1",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.13",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
