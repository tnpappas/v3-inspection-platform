; Hoist drizzle packages to root node_modules so drizzle-kit can resolve them.
; Without this, drizzle-kit's internal require lookup fails on pnpm's strict layout.
public-hoist-pattern[]=*drizzle*
public-hoist-pattern[]=@types/*

; Allow pnpm to install peer deps automatically when missing.
auto-install-peers=true

; Strict peer deps; warns but does not fail.
strict-peer-dependencies=false
