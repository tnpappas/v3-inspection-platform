{
  "name": "v3-inspection-platform",
  "version": "0.0.0",
  "private": true,
  "description": "v3 inspection platform (ISN replacement). Multi-business scheduling, dispatch, reports.",
  "type": "module",
  "engines": {
    "node": ">=22.14.0",
    "pnpm": ">=9.15.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r --filter \"./apps/**\" --filter \"./packages/**\" build",
    "dev": "pnpm -r --parallel --filter \"./apps/**\" dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\" --ignore-path .gitignore",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist build .turbo *.tsbuildinfo && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.1"
  }
}
