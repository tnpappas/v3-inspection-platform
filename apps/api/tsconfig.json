{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "lib": ["ES2023"],
    "types": ["node"],
    // Same Drizzle circular-reference loosening as @v3/db, since apps/api
    // imports schema.ts transitively. See packages/db/tsconfig.json.
    "noImplicitAny": false
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "tests"]
}
