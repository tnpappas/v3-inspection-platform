{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "noEmit": true,
    "composite": false,
    "incremental": false,
    "verbatimModuleSyntax": false
  },
  "include": ["src/**/*", "vite.config.ts"],
  "exclude": ["dist", "node_modules"],
  "references": [{ "path": "../../packages/types" }]
}
